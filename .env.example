# ===========================================================================
# 旅行地图智能助手 — 环境变量配置模板
# 使用方式：cp .env.example .env  然后填入你的真实 Key
# 切勿将填好 Key 的 .env 文件提交到 Git
# ===========================================================================

# ===== 高德地图（国内地图 + 地理编码，强烈建议配置）=====
# 同一个账号需要创建两种类型的 Key：
#   1. REST API Key  → 选「Web 服务」类型  → 填入 AMAP_API_KEY
#   2. JS API Key    → 选「Web 端(JS API)」类型 → 填入 AMAP_JS_KEY
# 申请入口：https://console.amap.com/dev/key/app
#
# 未配置时：地图总览 / 轨迹回放使用 Leaflet + ESRI 降级显示（国内可能加载慢）
#           地点搜索自动切换 Nominatim（OpenStreetMap，境外地点正常，国内较慢）
AMAP_API_KEY=""
AMAP_JS_KEY=""
# 安全密钥（控制台 → 应用 → 数字签名 → 安全密钥），没有可留空
AMAP_SECURITY_CODE=""

# ===== LLM 基础配置 =====
# 可选值: openai | deepseek | kimi | custom | none
# none = 规则降级模式，无 AI 能力，但地图/相册/报告功能正常使用
LLM_PROVIDER="none"
LLM_TEMPERATURE="0.3"
LLM_MAX_TOKENS="1800"

# 是否启用反思机制（对最终答复做质量校验 + 最多一次自动重试）
AGENT_ENABLE_REFLECTION="true"

# ===== 上下文预算（可按成本/效果调优）=====
CTX_TOTAL_TOKENS="3000"
CTX_HISTORY_TOKENS="1000"
CTX_MEMORY_TOKENS="600"
CTX_SPOT_TOKENS="1000"
AUTO_COMPRESS_THRESHOLD_TOKENS="6000"

# ===== OpenAI =====
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# ===== DeepSeek（OpenAI 兼容，性价比高，推荐）=====
# 申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# ===== Kimi / Moonshot（OpenAI 兼容）=====
# 申请：https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=""
KIMI_MODEL="moonshot-v1-8k"
KIMI_BASE_URL="https://api.moonshot.cn/v1"

# ===== 自定义 OpenAI 兼容网关（支持本地 Ollama / vLLM 等）=====
CUSTOM_API_KEY=""
CUSTOM_MODEL=""
CUSTOM_BASE_URL=""

# ===== 向量记忆（可选加强，仅 openai/custom provider 有效）=====
# 设为 true 时 memory 检索会额外调用 text-embedding-3-small 做语义重排
# 默认 false：使用 n-gram 余弦相似度（免费，无需额外 API 调用）
MEMORY_USE_EMBEDDINGS="false"
